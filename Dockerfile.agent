FROM golang:alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .

# Build the standalone agent binary
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/agent ./cmd/agent/

# Use an incredibly small final image (~15MB total)
FROM alpine:latest
RUN apk --no-cache add ca-certificates

WORKDIR /app
COPY --from=builder /bin/agent /app/agent

# Automatically execute the agent and pass any environment variables through
ENTRYPOINT ["/app/agent"]
